# First admin account — used only to bootstrap an empty users table;
# afterwards accounts are managed in the portal at /admin/users
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Session signing secret — any long random string
AUTH_SECRET=generate-a-long-random-hex-string

# Inquiry email notifications (optional — leave unset to disable).
# Use the firm's own SMTP account so correspondence stays on firm
# infrastructure. Port 465 = TLS; anything else uses STARTTLS.
#SMTP_HOST=mail.bekalawfirm.com
#SMTP_PORT=465
#SMTP_USER=portal@bekalawfirm.com
#SMTP_PASS=change-me
#SMTP_FROM=portal@bekalawfirm.com
#INQUIRY_NOTIFY_TO=info@bekalawfirm.com

# Beka Legal Information Assistant. The browser calls only same-origin Next.js
# routes; this private FastAPI URL and shared key must never use NEXT_PUBLIC_.
RAG_SERVICE_URL=http://127.0.0.1:8001
RAG_INTERNAL_API_KEY=generate-a-separate-random-secret-at-least-32-characters

# Canonical public origin used when the CMS synchronizes published website pages.
PUBLIC_SITE_URL=http://localhost:3000
